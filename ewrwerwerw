// ============================================================
// Google Doc auto-sync for the GE Updates Feed
// ============================================================
// Create a Google Doc where updates get pasted in (text and/or images), and separate each
// individual update with a blank line. Replace the ID below with that Doc's ID — the long
// string in its URL: https://docs.google.com/document/d/THIS_PART_HERE/edit
//
// NOTE: Opening this Doc requires the https://www.googleapis.com/auth/documents.readonly OAuth
// scope (this feature only reads the Doc's content — it never writes back to it). After setting
// a real ID here (or the first time this deploys), run getUpdatesDocFeed directly from the Apps
// Script editor once to trigger the consent screen and grant Docs access, then redeploy the web
// app (Deploy > Manage deployments > Edit > New version) so the change takes effect for users.
// Skipping this step causes: "Exception: Specified permissions are not sufficient to call
// DocumentApp.openById. Required permissions: .../auth/documents" (or .../documents.readonly)
const UPDATES_DOC_ID = "REPLACE_WITH_YOUR_DOC_ID";

/**
 * Reads the Updates Doc and turns each blank-line-separated chunk of content into one feed
 * item, including any inline image(s) pasted directly into that chunk. Most recent update
 * (assumed to be pasted at the top of the doc) is shown first.
 */
function getUpdatesDocFeed() {
  try {
    const doc = DocumentApp.openById(UPDATES_DOC_ID);
    const body = doc.getBody();
    const numChildren = body.getNumChildren();

    const feedItems = [];
    let currentText = '';
    let currentImages = [];

    const flushCurrentItem = () => {
      if (currentText.trim() !== '' || currentImages.length > 0) {
        feedItems.push({ text: currentText.trim(), images: currentImages });
      }
      currentText = '';
      currentImages = [];
    };

    for (let i = 0; i < numChildren; i++) {
      const el = body.getChild(i);
      if (el.getType() !== DocumentApp.ElementType.PARAGRAPH) continue;

      const paragraph = el.asParagraph();
      const paragraphText = paragraph.getText();
      const paragraphImages = [];

      // Inline images — embedded directly in the text flow
      const numPieces = paragraph.getNumChildren();
      for (let j = 0; j < numPieces; j++) {
        const piece = paragraph.getChild(j);
        if (piece.getType() === DocumentApp.ElementType.INLINE_IMAGE) {
          try {
            const blob = piece.asInlineImage().getBlob();
            const base64Data = Utilities.base64Encode(blob.getBytes());
            paragraphImages.push(`data:${blob.getContentType()};base64,${base64Data}`);
          } catch (imgErr) {
            console.error('Failed to read an inline image from the Updates Doc: ', imgErr);
          }
        }
      }

      // Positioned/floating images — pasting sometimes creates these instead of inline images,
      // and they aren't reachable via getChild(), which was the root cause of images ending up
      // misattributed to the wrong (usually last) entry.
      const positionedIds = paragraph.getPositionedImageIds ? paragraph.getPositionedImageIds() : [];
      positionedIds.forEach(id => {
        try {
          const posImg = paragraph.getPositionedImage(id);
          const blob = posImg.getBlob();
          const base64Data = Utilities.base64Encode(blob.getBytes());
          paragraphImages.push(`data:${blob.getContentType()};base64,${base64Data}`);
        } catch (imgErr) {
          console.error('Failed to read a positioned image from the Updates Doc: ', imgErr);
        }
      });

      const isBlankParagraph = paragraphText.trim() === '' && paragraphImages.length === 0;

      if (isBlankParagraph) {
        // A genuinely empty line (no text, no image at all) = separator between updates
        flushCurrentItem();
        continue;
      }

      if (paragraphText.trim() !== '') {
        currentText += (currentText ? '\n' : '') + paragraphText;
      }
      currentImages = currentImages.concat(paragraphImages);
    }
    flushCurrentItem();

    feedItems.reverse(); // newest-pasted-at-top shows first

    return {
      success: true,
      messages: feedItems.map(item => ({ text: item.text, sender: '', timestamp: '', images: item.images }))
    };
  } catch (e) {
    console.error('Error reading the Updates Doc: ', e);
    return { success: false, error: e.toString(), messages: [] };
  }
}

