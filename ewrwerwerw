/**
 * Fetches the porting troubleshooting reference from the "PortingIssues" sheet tab, for the
 * Porting Issues popup. The sheet is one row per step; this groups steps under their category
 * and sorts both categories and steps by their Order columns.
 * Expected column order: A=Category ID, B=Category Order, C=Category Title, D=Error Code,
 * E=Step Order, F=Step Text, G=Template Copy Text, H=Escalate, I=Escalation Description,
 * J=Escalation Type, K=Escalation Priority.
 *
 * Step Text supports two bits of author-facing syntax, parsed on the client:
 *   "- some line"                          -> renders as a bullet
 *   "{{link text->target-category-id}}"    -> renders as a clickable cross-reference jump
 */
function getPortingIssuesData() {
  try {
    const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
    const sheet = ss.getSheetByName('PortingIssues');
    if (!sheet) return [];

    const data = sheet.getDataRange().getValues();
    if (data.length <= 1) return [];

    const categoriesById = {};
    const seenOrder = [];

    data.slice(1).forEach(row => {
      const catId = row[0] ? row[0].toString().trim() : '';
      if (!catId) return; // skip blank/spacer rows

      if (!categoriesById[catId]) {
        const orderVal = row[1];
        categoriesById[catId] = {
          id: catId,
          order: (orderVal !== '' && orderVal !== null && !isNaN(orderVal)) ? Number(orderVal) : 999,
          title: row[2] ? row[2].toString().trim() : '',
          errorCode: row[3] ? row[3].toString().trim() : '',
          steps: []
        };
        seenOrder.push(catId);
      }

      const stepText = row[5] ? row[5].toString().trim() : '';
      const templateText = row[6] ? row[6].toString() : '';
      if (!stepText && !templateText) return; // skip placeholder rows with no step content yet

      const stepOrderVal = row[4];
      categoriesById[catId].steps.push({
        order: (stepOrderVal !== '' && stepOrderVal !== null && !isNaN(stepOrderVal))
          ? Number(stepOrderVal) : categoriesById[catId].steps.length + 1,
        text: stepText,
        template: templateText,
        escalate: row[7] ? row[7].toString().trim().toLowerCase() === 'yes' : false,
        escalationDescription: row[8] ? row[8].toString().trim() : '',
        escalationType: row[9] ? row[9].toString().trim() : '',
        escalationPriority: row[10] ? row[10].toString().trim() : ''
      });
    });

    const categories = Object.keys(categoriesById).map(id => categoriesById[id]);
    categories.forEach(cat => cat.steps.sort((a, b) => a.order - b.order));
    categories.sort((a, b) => a.order - b.order);
    return categories;
  } catch (e) {
    console.error('Error fetching porting issues data: ', e);
    return [];
  }
}

/**
 * Fetches the Fraud Troubleshooting guide from the "FraudTS" sheet tab, for the Fraud
 * Troubleshooting popup. Unlike Porting Issues, this content is deeply nested (multi-level
 * lettered/roman sub-steps, private-note templates, escalation ticket fields) rather than a flat
 * list of steps, so the schema is one row per "block" rather than one row per step:
 *
 * A=Section ID, B=Section Order, C=Section Title, D=Section Subtitle, E=Persistent (Yes = always
 * shown, not collapsible — used for the intro), F=Subsection Title (blank continues the previous
 * subsection within the section), G=Block Order, H=Block Type, I=Content, J=Block ID,
 * K=Escalate Description, L=Escalate Type, M=Escalate Priority, N=Template Text.
 *
 * Block Type is one of:
 *   "html"            — raw HTML (ol/li/p/strong/a) inserted as-is; may contain the tokens
 *                        {{link text->target-section-id}} (cross-reference jump),
 *                        [[ESCALATE:block-id]] and [[TEMPLATE:block-id]] (inline components,
 *                        resolved against escalate-def/template-def rows sharing that Block ID —
 *                        this is what lets an escalation block or copy-template render at an
 *                        exact nested position inside a step, rather than only ever appearing
 *                        after a block).
 *   "callout-warning"/"callout-redirect"/"callout-danger" — a plain-text/light-HTML callout box.
 *   "escalate-def"    — not rendered in sequence; just supplies data (Escalate Description/Type/
 *                        Priority) for a matching [[ESCALATE:id]] token elsewhere in the section.
 *   "template-def"    — same idea, supplies Template Text for a [[TEMPLATE:id]] token.
 */
function getFraudGuideData() {
  try {
    const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
    const sheet = ss.getSheetByName('FraudTS');
    if (!sheet) return [];

    const data = sheet.getDataRange().getValues();
    if (data.length <= 1) return [];

    const sectionsById = {};
    const seenOrder = [];

    data.slice(1).forEach(row => {
      const sectionId = row[0] ? row[0].toString().trim() : '';
      if (!sectionId) return; // skip blank/spacer rows

      if (!sectionsById[sectionId]) {
        const orderVal = row[1];
        sectionsById[sectionId] = {
          id: sectionId,
          order: (orderVal !== '' && orderVal !== null && !isNaN(orderVal)) ? Number(orderVal) : 999,
          title: row[2] ? row[2].toString().trim() : '',
          subtitle: row[3] ? row[3].toString().trim() : '',
          persistent: row[4] ? row[4].toString().trim().toLowerCase() === 'yes' : false,
          subsections: [],
          defs: {}
        };
        seenOrder.push(sectionId);
      }
      const section = sectionsById[sectionId];

      const subsectionTitle = row[5] ? row[5].toString().trim() : '';
      const blockOrderVal = row[6];
      const blockType = row[7] ? row[7].toString().trim() : 'html';
      const content = row[8] ? row[8].toString() : '';
      const blockId = row[9] ? row[9].toString().trim() : '';
      const escDescription = row[10] ? row[10].toString().trim() : '';
      const escType = row[11] ? row[11].toString().trim() : '';
      const escPriority = row[12] ? row[12].toString().trim() : '';
      const templateText = row[13] ? row[13].toString() : '';

      // Def rows are pure data — they never render in sequence, so they're keyed into defs
      // rather than pushed onto a subsection's block list.
      if (blockType === 'escalate-def') {
        if (blockId) section.defs[blockId] = { type: 'escalate', description: escDescription, issueType: escType, priority: escPriority };
        return;
      }
      if (blockType === 'template-def') {
        if (blockId) section.defs[blockId] = { type: 'template', text: templateText };
        return;
      }

      // A non-blank Subsection Title starts a new named subsection; a blank one continues
      // whichever subsection was most recently opened (or starts an untitled one if none yet).
      let subsection = section.subsections.length ? section.subsections[section.subsections.length - 1] : null;
      if (subsectionTitle) {
        subsection = { title: subsectionTitle, blocks: [] };
        section.subsections.push(subsection);
      } else if (!subsection) {
        subsection = { title: '', blocks: [] };
        section.subsections.push(subsection);
      }

      subsection.blocks.push({
        order: (blockOrderVal !== '' && blockOrderVal !== null && !isNaN(blockOrderVal)) ? Number(blockOrderVal) : subsection.blocks.length + 1,
        type: blockType,
        content: content
      });
    });

    const sections = Object.keys(sectionsById).map(id => sectionsById[id]);
    sections.forEach(section => section.subsections.forEach(sub => sub.blocks.sort((a, b) => a.order - b.order)));
    sections.sort((a, b) => a.order - b.order);
    return sections;
  } catch (e) {
    console.error('Error fetching fraud guide data: ', e);
    return [];
  }
}


